# ============================================
# Stash Auto Vision - CPU Configuration
# ============================================
# Copy this file to .env for CPU-only platforms

# Media Paths
# Path to your test video files (will be mounted to /media/videos in containers)
# Testing with Charades dataset for frame/scene testing
TEST_MEDIA_PATH=/tests/data
# Path to your live video files (will be mounted to /data in containers)
SERVER_MEDIA_PATH=/mnt/user/movies

# Docker Configuration
DOCKER_NETWORK=stash-auto-vision-network
DOCKER_RUNTIME=runc

# Service Ports
VISION_API_PORT=5010
FRAME_SERVER_PORT=5001
SCENES_PORT=5002
FACES_PORT=5003
SEMANTICS_PORT=5004
OBJECTS_PORT=5005
RESOURCE_MANAGER_PORT=5007
SCHEMA_PORT=5009
JOBS_VIEWER_PORT=5020
REDIS_PORT=6379

# Frame Server (CPU Mode)
FRAME_SERVER_DOCKERFILE=Dockerfile.cpu
FRAME_EXTRACTION_METHOD=opencv_cpu
OPENCV_DEVICE=cpu
ENABLE_FALLBACK=true  # Enable automatic fallback: opencv -> pyav_hw -> pyav_sw -> ffmpeg
ENABLE_ENHANCEMENT=false  # Enable face enhancement
ENHANCEMENT_MODEL=codeformer  # gfpgan or codeformer
MAX_ENHANCEMENT_PIXELS=2073600 # 1080p

# Scenes Service (CPU Mode)
SCENES_DOCKERFILE=Dockerfile.cpu
SCENES_DETECTOR=pyscenedetect_cpu
SCENES_THRESHOLD=27.0  # Default threshold for ContentDetector (0.0-100.0, can be overridden per-request)

# Faces Service (CPU Mode)
FACES_DOCKERFILE=Dockerfile.cpu
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_DEVICE=cpu
INSIGHTFACE_COMPUTE_TYPE=int8
FACES_MIN_CONFIDENCE=0.9  # Default confidence threshold (0.0-1.0, can be overridden per-request)
FACES_MIN_QUALITY=0.0  # Default minimum quality threshold (0.0-1.0, can be overridden per-request)
FACES_ENHANCEMENT_QUALITY_TRIGGER=0.5  # Default quality trigger for enhancement (0.0-1.0, can be overridden per-request)

# Faces Service - ONNX model download (bootstrap.py at container start)
# Resolution order per model: local path → configured HF → default HF
# Required model: occlusion_classifier.onnx (no model = unhealthy /faces/health)
# Optional models: topiq_nr.onnx, clipiqa_plus.onnx (best-effort, no health impact)
FACES_HF_REPO=smegmarip/face-recognition  # HuggingFace repo hosting the ONNX weights
FACES_HF_OCCLUSION_MODEL=models/occlusion_classifier.onnx  # Path within the repo
FACES_HF_TOPIQ_MODEL=models/topiq_nr.onnx  # Path within the repo (optional)
FACES_HF_CLIPIQA_MODEL=models/clipiqa_plus.onnx  # Path within the repo (optional)
FACES_HF_TOKEN=  # Optional HF token for gated/private forks
# Pre-downloaded model overrides (absolute paths inside the container)
# When set, bypasses HF download entirely. Intended for air-gapped deployments.
FACES_LOCAL_OCCLUSION_PATH=  # e.g. /app/models/occlusion_classifier.onnx
FACES_LOCAL_TOPIQ_PATH=      # e.g. /app/models/topiq_nr.onnx
FACES_LOCAL_CLIPIQA_PATH=    # e.g. /app/models/clipiqa_plus.onnx
FACES_MODEL_CACHE_DIR=/app/models  # Volume-backed cache, must match docker-compose mount

# Faces Service - Model lifecycle (deferred loading via resource-manager)
FACES_MODEL_IDLE_TIMEOUT=300  # Seconds before idle models are unloaded from memory
FACES_VRAM_MB=2600            # VRAM budget for GPU lease request (no-op on CPU)

# Semantics Service (CPU Mode) - Tag Classifier
SEMANTICS_DOCKERFILE=Dockerfile.cpu
CLASSIFIER_MODEL=text-only  # Model variant: 'vision', 'text-only', or path to checkpoint
CLASSIFIER_DEVICE=cpu  # CPU mode (slow but functional for testing)
SEMANTICS_MIN_CONFIDENCE=0.75  # Default confidence threshold (0.0-1.0, can be overridden per-request)
SEMANTICS_TAG_ID=  # Root tag ID for taxonomy subtree (empty = all tags)
SEMANTICS_HF_REPO=smegmarip/tag-classifier  # HuggingFace repo for model weights
SEMANTICS_HF_VISION_MODEL=vision/best_model.pt
SEMANTICS_HF_TEXT_MODEL=text-only/best_model.pt
SEMANTICS_HF_VISION_TAG_MAPPING=vision/tag_mapping.json
SEMANTICS_HF_TEXT_TAG_MAPPING=text-only/tag_mapping.json
# Semantics Service - LLM model for scene summary generation
SEMANTICS_LLM_MODEL=RedHatAI/Llama-3.1-8B-Instruct  # Llama model for summary generation
SEMANTICS_LLM_DEVICE=cpu   # cpu required on this profile (~30x slower than cuda)
SEMANTICS_HF_TOKEN=        # HuggingFace token (optional, for gated models)

# Semantics Service - Job queue and model lifecycle
SEMANTICS_MODEL_IDLE_TIMEOUT=300  # Seconds before idle models are unloaded from memory
SEMANTICS_JOB_LOCK_TTL=3600       # Max seconds a job can hold the active lock (1h default)
SEMANTICS_WORKER_ID=              # Worker identifier (defaults to hostname if empty)
SEMANTICS_MEMORY_LIMIT=40G        # Container RAM limit (Llama 3.1 8B bfloat16 needs ~16GB + peak load overhead)

# Objects Service (CPU Mode) - Phase 4
OBJECTS_DOCKERFILE=Dockerfile.cpu
YOLO_MODEL=yolo-world-s  # Smaller model for CPU
YOLO_DEVICE=cpu
OBJECTS_STUB_MODE=true  # Set to false when implementing
OBJECTS_MIN_CONFIDENCE=0.5  # Default confidence threshold for YOLO (0.0-1.0, can be overridden per-request)

# Stash Integration (for taxonomy sync)
STASH_URL=http://host.docker.internal:9999  # Stash instance URL for tag taxonomy
STASH_API_KEY=  # Stash API key (leave empty if no auth required)

# Resource Management (CPU Mode - basic implementation without actual resource tracking)
RESOURCE_MANAGER_DOCKERFILE=Dockerfile.cpu
RESOURCE_MANAGER_PORT=5007
TOTAL_VRAM_MB=16384  # Total VRAM in MB for GPU resource management
LEASE_DURATION_SECONDS=600  # 10 minutes
HEARTBEAT_TIMEOUT_SECONDS=60  # 1 minute

# Cache Configuration
CACHE_TTL=31536000  # seconds (1 year - for job history retention)

# Frame Storage Configuration
FRAME_TTL_HOURS=2  # Automatic cleanup after 2 hours
FRAME_DIR=/tmp/frames

# Processing
PROCESSING_MODE=sequential  # Parallel not recommended on CPU

# Logging
LOG_LEVEL=DEBUG  # More verbose for development
